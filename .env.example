# ============================================================
# Flask
# ============================================================
SECRET_KEY=change-me-to-a-random-string
FLASK_DEBUG=false

# ============================================================
# MongoDB
# Local Docker Compose (default):
MONGO_URI=mongodb://mongo:27017/Bookify
# MongoDB Atlas (production) — uncomment and fill in:
# MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/Bookify?retryWrites=true&w=majority
# ============================================================

# ============================================================
# Airflow — on Linux run: echo "AIRFLOW_UID=$(id -u)" >> .env
# On macOS the default 50000 is fine.
# ============================================================
AIRFLOW_UID=50000

# ============================================================
# Pipeline tuning — lower MIN_SUPPORT if rules are sparse
# ============================================================
PIPELINE_MIN_SUPPORT=0.01
PIPELINE_MIN_LIFT=1.0
